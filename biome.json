{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["@kontent-ai/biome-config/base"],
  "files": {
    "includes": ["src/**", "!**/package.json", "!**/*.snap.*"]
  },
  "linter": {
    "rules": {
      "correctness": {
        "useImportExtensions": "off"
      },
      "complexity": {
        "noVoid": "off"
      }
    }
  }
}
